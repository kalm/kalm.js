{
    "compilerOptions": {
        "module": "none",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "noImplicitAny": false,
        "removeComments": true,
        "preserveConstEnums": true,
        "sourceMap": false,
        "allowJs": true,
        "target": "es2020",
        "outDir": "dist",
        "types": [
            "jest",
            "node"
        ]
    },
    "include": [
        "./packages",
        "./src",
        "./types.d.ts"
    ],
    "exclude": [
        "./tests/**/*.ts",
        "**/*.spec.ts",
        "node_modules",
    ]
}